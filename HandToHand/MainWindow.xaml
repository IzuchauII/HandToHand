<Window x:Class="HandToHand.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HandToHand"
        mc:Ignorable="d"
        Title="HandToHand" 
        Height="500"
        ResizeMode="CanResizeWithGrip"
        Width="380" 
        Background="Transparent" 
        WindowStartupLocation="CenterScreen"
        Icon="/Images/logo_icon.ico"
        WindowStyle="None"
        AllowsTransparency="True">
        
    <Window.Resources>
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ScrollContentPresenter Grid.Column="0"/>

                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Grid.Column="1"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Width="4"
                                       Margin="4,0,0,0">
                                <ScrollBar.Template>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid Background="Transparent">
                                            <Track x:Name="PART_Track" IsDirectionReversed="true">
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Background="AliceBlue" CornerRadius="2"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </ScrollBar.Template>
                            </ScrollBar>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    
    
    <Grid>
        <Border 
                BorderBrush="#40FFFFFF" 
                BorderThickness="1"
                MouseDown="Border_MouseDown"
                CornerRadius="15">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF060510"/>
                    <GradientStop Color="#FF4F449D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,0,0,10" Name="ChatHistoryScrollViewer">
                    <TextBlock Name="ChatLog" 
                               Text="Ожидаю запрос" 
                               TextWrapping="Wrap" 
                               Foreground="White"/>
                </ScrollViewer>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Name="AttachFileButton" 
            Grid.Column="0"
            Width="40" 
            Height="40"
            Click="AttachFileButton_Click"
            Cursor="Hand"
            Margin="0,0,10,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    CornerRadius="20">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9" />
                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#8800AAFF"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>

                        <Image Source="/Images/attach_icon.png" Width="24" Height="24">
                            <Image.Effect>
                                <DropShadowEffect Color="DeepSkyBlue" BlurRadius="10" ShadowDepth="0" Opacity="0.7"/>
                            </Image.Effect>
                        </Image>
                    </Button>

                    <TextBox Name="UserInput" 
             Grid.Column="1"
             MinHeight="30"
             MaxHeight="180"
             VerticalScrollBarVisibility="Auto"                       
             KeyDown="UserInput_KeyDown"
             TextChanged="UserInput_TextChanged"
             VerticalContentAlignment="Top" 
             Margin="0,0,10,0"
             Padding="5,5,0,5"
             TextWrapping="Wrap"
             Foreground="White">
                        <TextBox.BorderBrush>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF1E2228"/>
                                <GradientStop Color="White" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBox.BorderBrush>
                        <TextBox.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF50459F" Offset="1"/>
                                <GradientStop Color="#FF1E2228"/>
                            </LinearGradientBrush>
                        </TextBox.Background>
                    </TextBox>

                    <Button Name="SendButton" 
            Grid.Column="2"
            Width="40" 
            Height="40"
            Click="SendButton_Click"
            Cursor="Hand"
            Margin="0,0,5,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    CornerRadius="20">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9" />
                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#88FF5500"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Image Source="/Images/star_icon.png" Width="26" Height="26">
                            <Image.Effect>
                                <DropShadowEffect Color="Orange" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                            </Image.Effect>
                        </Image>
                    </Button>

                    <Button Name="DeleteAllMessage" 
            Grid.Column="3"
            Width="40" 
            Height="40"
            Click="DeleteAllMessage_Click"
            Cursor="Arrow"
            Margin="0,0,5,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    CornerRadius="20">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.9" />
                                        <Setter Property="Background" Value="#33FFFFFF"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Background" Value="#88FF2222"/>
                                        <Setter Property="RenderTransform">
                                            <Setter.Value>
                                                <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                                            </Setter.Value>
                                        </Setter>
                                        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Image Source="/Images/trash_icon.png" Width="24" Height="24">
                            <Image.Effect>
                                <DropShadowEffect Color="Crimson" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                            </Image.Effect>
                        </Image>
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
    
   